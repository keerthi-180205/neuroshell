.env
.env.local
.env.*.local

# ── Python Artifacts ──────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.pyc

# ── Distribution / Packaging ──────────────
dist/
build/
*.egg-info/
*.egg
.eggs/
wheels/

# ── Testing ───────────────────────────────
.pytest_cache/
.coverage
htmlcov/
*.xml

# ── Jupyter Notebooks ─────────────────────
.ipynb_checkpoints/
*.ipynb

# ── IDE & Editor Files ────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS Files ──────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ──────────────────────────────────
*.log
logs/

# ── NeuroShell Specific ───────────────────
